# ── Local dev ──────────────────────────────────────────
# Leave DATABASE_URL empty → embedded PGlite (Postgres-in-WASM).
# No server needed. Data persists in .pglite/ directory.

# ── Railway (production) ───────────────────────────────
# When you add the PostgreSQL plugin to your Railway project,
# Railway sets DATABASE_URL automatically.
# You only need to set JWT_SECRET manually in the Railway dashboard:
#   Variables → New Variable → JWT_SECRET → <long-random-string>
#
# Railway sets NODE_ENV=production automatically.

DATABASE_URL=

# Auth (required)
JWT_SECRET=change-me-to-a-long-random-string-in-production

# App
NODE_ENV=development
