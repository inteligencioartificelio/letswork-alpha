# Database: leave empty to use embedded PGlite (local dev, no server needed).
# For Railway/Postgres, set to your connection string, e.g.
# DATABASE_URL=postgresql://user:pass@abc.railway.app:5432/letswork
DATABASE_URL=

# Auth
JWT_SECRET=change-me-to-a-long-random-string-in-production
AUTH_URL=http://localhost:3000

# App
NODE_ENV=development
